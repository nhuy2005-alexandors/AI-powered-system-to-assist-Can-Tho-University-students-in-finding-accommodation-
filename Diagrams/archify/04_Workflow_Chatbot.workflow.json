    { "id": "cite", "lane": "rag", "col": 4, "type": "backend", "label": "Trích dẫn", "sublabel": "+ memory 5 lượt", "tag": "T9" },
    { "id": "answer", "lane": "sv", "col": 5, "type": "frontend", "label": "Answer", "sublabel": "+ link + nguồn" },
    { "id": "fallback", "lane": "sv", "col": 3, "type": "external", "label": "Fallback", "sublabel": "không tìm thấy" }
