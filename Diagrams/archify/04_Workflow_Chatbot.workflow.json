    { "dot": "emerald", "title": "RAG Pipeline", "items": ["Embed e5-small multilingual", "Top-5 chunks từ pgvector", "Gắn nguồn trích dẫn vào answer"] },
    { "dot": "cyan", "title": "T9 — Multi-turn", "items": ["Conversation Memory nhớ 5 lượt", "Kết hợp câu hỏi mới + ngữ cảnh cũ", "Faithfulness ≥0.7, AnsRel ≥0.75"] }
  ]
