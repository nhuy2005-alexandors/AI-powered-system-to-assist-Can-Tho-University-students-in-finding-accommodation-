# Postgres (PostGIS + pgvector)
POSTGRES_USER=nckh
POSTGRES_PASSWORD=nckh
POSTGRES_DB=nckh

# Wired into services by docker-compose; override for non-docker local runs
DATABASE_URL=postgresql+psycopg://nckh:nckh@db:5432/nckh
REDIS_URL=redis://redis:6379/0
NEXT_PUBLIC_API_URL=http://localhost:8000

# Auth — ĐẶT GIÁ TRỊ THẬT trong .env, KHÔNG commit
JWT_SECRET=change-me-random-64-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=30
GOOGLE_CLIENT_ID=
