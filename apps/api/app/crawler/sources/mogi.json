{
  "source": "mogi",
  "base_url": "https://mogi.vn",
  "name": "Mogi Cần Thơ",
  "list_url": "https://mogi.vn/can-tho/thue-nha-dat",
  "list_page_param": "?cp={page}",
  "incremental_pages": 2,
  "full_pages": 10,
  "max_detail_incremental": 20,
  "use_jsonld": false,
  "item_mode": "self",
  "selectors": {
    "item": "ul.props li",
    "item_anchor": "a.link-overlay",
    "item_url_attr": "href",
    "title": "h2.prop-title",
    "price": ".price",
    "district": ".prop-addr",
    "thumb": ".prop-img img"
  },
  "detail": {
    "description_body": ".info-content-body",
    "images": "div.media-item img::attr(data-src), div.media-item img::attr(src), div.media-slider img::attr(src), .property-slider img::attr(src)",
    "contact_name": ".agent-name",
    "contact_phone": ".agent-contact span[ng-bind]"
  }
}
